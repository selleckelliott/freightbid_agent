__pycache__/
*.pyc
.pytest_cache/
.venv/
.env
*.egg-info/
.ipynb_checkpoints/

benchmarks/scenarios/gen/
# Scratch/smoke artifacts (underscore-prefixed) from local benchmark runs.
benchmarks/_*
# Default scratch output of `chart_results.py` (regenerable; the canonical 1,000-scenario
# baseline chart is committed at benchmarks/results/heuristic_baseline_1000.png).
benchmarks/results_chart.png

# Phase 3.5 — non-destructive reproduce output (regenerable; committed demo
# assets live directly under benchmarks/).
benchmarks/reproduced/

# Phase 3.1 ML — generated history + trained binaries (seeded, regenerable).
# Metadata JSON is committed as a result artifact; the model binary is not.
# (Phase 4.1 winnability artifacts — winnability_{snapshots,outcomes,trials}.jsonl
# — are seeded & regenerable and fall under data/*.jsonl below.)
data/synthetic_load_history.jsonl
data/*.jsonl
ml/artifacts/*.joblib

# Phase 7.5 - production-readiness demo audit bundle (regenerable; the summary JSON +
# transcript under artifacts/ are committed, the exported bundle with volatile provenance is not).
artifacts/production_readiness_export/

# Microsoft Office owner-lock temp files (e.g. "~$Document.docx") - transient, never commit.
~$*
